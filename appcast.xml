    <!--
      HOW TO ADD A NEW RELEASE:
      1. Bump MARKETING_VERSION and CURRENT_PROJECT_VERSION in Xcode
      2. Build your .dmg
      3. Run: sign_update /path/to/Kaze.dmg
         (tool is at ~/Library/Developer/Xcode/DerivedData/Kaze-*/SourcePackages/artifacts/sparkle/Sparkle/bin/sign_update)
      4. Copy a new <item> block below, fill in version, signature, length, and download URL
      5. Commit appcast.xml to main, then create the GitHub Release with the .dmg

      Newest release goes on top.
    -->

    <item>
      <title>Version 0.76</title>
      <sparkle:version>7</sparkle:version>
      <sparkle:shortVersionString>0.76</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>15.0</sparkle:minimumSystemVersion>
      <pubDate>Wed, 12 Mar 2026 12:00:00 +0000</pubDate>
      <description><![CDATA[
        <h2>What's New in 0.76</h2>
        <ul>
          <li>Redesigned onboarding with permissions step, model downloads, and brand icons</li>
          <li>Reordered engines: Parakeet first (recommended/default), then Whisper, Qwen, Dictation</li>
          <li>Real download progress bars for all engine models during onboarding</li>
          <li>Fixed settings and about windows not appearing for accessory apps</li>
        </ul>
      ]]></description>
